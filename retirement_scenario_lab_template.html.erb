              <div class="stat-box"><div class="k">Ending value</div><div class="v mono">${currency(entry.endingNetWorth)}</div></div>
              <div class="stat-box"><div class="k">Lifetime federal tax</div><div class="v mono">${currency(entry.totals.federalTax)}</div></div>
              <div class="stat-box"><div class="k">Lifetime state tax</div><div class="v mono">${currency(entry.totals.stateTax)}</div></div>
              <div class="stat-box"><div class="k">Lifetime IRMAA</div><div class="v mono">${currency(entry.totals.irmaa)}</div></div>
