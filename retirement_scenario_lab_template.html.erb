<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Retirement Scenario Lab</title>
  <style>
    :root {
      --bg: #f4f6f9;
      --surface: #ffffff;
      --surface-2: #f8fafc;
      --border: #d8dee9;
      --text: #18202a;
      --muted: #68768a;
      --olive: #5c6342;
      --olive-2: #727b55;
      --nav-text: #f7f9fb;
      --blue: #3345d5;
      --blue-2: #2441ff;
      --blue-3: #eaf0ff;
      --ink: #1c2340;
      --good: #0d8a59;
      --warn: #ad7a00;
      --danger: #be3945;
      --shadow: 0 12px 30px rgba(27, 39, 72, 0.08);
      --radius: 16px;
      --radius-sm: 10px;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: linear-gradient(180deg, #eef2f7 0%, #f7f9fb 100%);
      color: var(--text);
    }

    .app-shell {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    .topbar {
      background: linear-gradient(180deg, var(--olive-2), var(--olive));
      color: var(--nav-text);
      padding: 12px 28px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
      box-shadow: 0 4px 14px rgba(0, 0, 0, 0.12);
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 14px;
      min-width: 240px;
    }

    .brand-lockup {
      border: 2px solid rgba(255, 255, 255, 0.9);
      color: white;
      padding: 6px 10px;
      border-radius: 2px;
      font-size: 12px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      font-weight: 700;
    }

    .brand-sub {
      display: flex;
      flex-direction: column;
      gap: 2px;
      line-height: 1.1;
    }

    .brand-sub .primary { font-size: 13px; font-weight: 600; }
    .brand-sub .secondary { font-size: 13px; opacity: 0.9; }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 22px;
      flex-wrap: wrap;
      justify-content: center;
      font-size: 14px;
      opacity: 0.95;
    }

    .nav-links span.active {
      border-bottom: 2px solid white;
      padding-bottom: 5px;
      font-weight: 600;
    }

    .page {
      width: min(1560px, calc(100vw - 32px));
      margin: 22px auto 28px;
      display: grid;
      grid-template-columns: 320px minmax(0, 1fr);
      gap: 22px;
    }

    .sidebar, .panel, .section-card, .metric-card, .table-card, .insight-card {
      background: var(--surface);
      border: 1px solid rgba(95, 113, 140, 0.15);
      box-shadow: var(--shadow);
    }

    .sidebar {
      border-radius: 20px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      min-height: 780px;
    }

    .sidebar-header {
      background: linear-gradient(180deg, #1d1732, #241b44);
      color: white;
      padding: 22px 22px 18px;
    }

    .sidebar-header .label {
      font-size: 14px;
      opacity: 0.85;
      margin-bottom: 6px;
    }

    .sidebar-header .value {
      font-size: 34px;
      font-weight: 700;
      letter-spacing: -0.03em;
    }

    .sidebar-header .sub {
      font-size: 12px;
      margin-top: 6px;
      opacity: 0.7;
    }

    .bucket-list {
      display: flex;
      flex-direction: column;
      padding: 0;
      margin: 0;
      list-style: none;
      border-top: 1px solid rgba(255, 255, 255, 0.07);
    }

    .bucket-row {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 8px;
      align-items: center;
      padding: 18px 22px;
      border-bottom: 1px solid var(--border);
      cursor: default;
    }

    .bucket-row .bucket-name {
      font-size: 13px;
      color: var(--muted);
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }

    .bucket-row .bucket-total {
      font-size: 23px;
      font-weight: 700;
      color: var(--ink);
      text-align: right;
    }

    .bucket-row .bucket-count {
      grid-column: 1 / -1;
      font-size: 12px;
      color: var(--muted);
      margin-top: -2px;
    }

    .account-mini-list {
      padding: 16px 18px 20px;
      overflow: auto;
      max-height: 360px;
      background: linear-gradient(180deg, #fff, #fcfdff);
    }

    .account-mini {
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 12px 12px 10px;
      margin-bottom: 10px;
      background: white;
    }

    .account-mini:last-child { margin-bottom: 0; }

    .account-mini .title {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      font-size: 14px;
      font-weight: 600;
      margin-bottom: 4px;
    }

    .account-mini .meta {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      font-size: 12px;
      color: var(--muted);
    }

    .content {
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 18px;
    }

    .hero {
      background: radial-gradient(circle at top left, rgba(80, 100, 230, 0.08), transparent 46%),
                  linear-gradient(180deg, #ffffff 0%, #f6f8fc 100%);
      border-radius: 22px;
      padding: 22px 24px 18px;
      border: 1px solid rgba(95, 113, 140, 0.15);
      box-shadow: var(--shadow);
      position: relative;
      overflow: hidden;
    }

    .hero::after {
      content: "";
      position: absolute;
      right: -70px;
      bottom: -70px;
      width: 260px;
      height: 260px;
      background: linear-gradient(180deg, rgba(51, 69, 213, 0.12), rgba(51, 69, 213, 0));
      transform: rotate(16deg);
      border-radius: 34px;
    }

    .hero-top {
      position: relative;
      z-index: 1;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 24px;
      flex-wrap: wrap;
    }

    .hero h1 {
      margin: 0;
      font-size: 40px;
      line-height: 1;
      letter-spacing: -0.05em;
      font-weight: 700;
    }

    .hero p {
      margin: 10px 0 0;
      color: var(--muted);
      max-width: 780px;
      font-size: 15px;
    }

    .hero-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .btn, button, select, input, textarea {
      font: inherit;
    }

    .btn {
      border: 0;
      border-radius: 12px;
      padding: 11px 16px;
      cursor: pointer;
      font-weight: 600;
      transition: transform 120ms ease, box-shadow 120ms ease, background 120ms ease;
      box-shadow: 0 8px 20px rgba(51, 69, 213, 0.12);
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }

    .btn:hover { transform: translateY(-1px); }
    .btn-primary { background: linear-gradient(180deg, #4255f4, #3146d2); color: white; }
    .btn-secondary { background: white; color: var(--ink); border: 1px solid var(--border); box-shadow: none; }
    .btn-ghost { background: var(--blue-3); color: var(--blue); box-shadow: none; }
    .btn-danger { background: #fff2f2; color: var(--danger); box-shadow: none; }
    .btn-sm { padding: 8px 12px; font-size: 13px; border-radius: 10px; }

    .tabs {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      padding: 0;
      margin: 0;
      list-style: none;
    }

    .tab-button {
      border: 1px solid var(--border);
      background: white;
      color: var(--muted);
      border-radius: 12px;
      padding: 10px 14px;
      cursor: pointer;
      font-weight: 600;
    }

    .tab-button.active {
      background: var(--blue-3);
      color: var(--blue);
      border-color: rgba(51, 69, 213, 0.24);
    }

    .tab-panel { display: none; gap: 16px; }
    .tab-panel.active { display: flex; flex-direction: column; }

    .grid-2 { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; }
    .grid-3 { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16px; }

    .section-card {
      border-radius: 20px;
      padding: 18px 18px 16px;
    }

    .section-title {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 14px;
    }

    .section-title h2, .section-title h3 {
      margin: 0;
      font-size: 24px;
      letter-spacing: -0.03em;
    }

    .section-title p {
      margin: 4px 0 0;
      color: var(--muted);
      font-size: 13px;
    }

    .field-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .field {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .field label {
      font-size: 12px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      font-weight: 700;
    }

    .field input, .field select, .field textarea {
      width: 100%;
      border-radius: 12px;
      border: 1px solid var(--border);
      background: #ffffff;
      padding: 11px 12px;
      color: var(--text);
      outline: none;
    }

    .field input:focus, .field select:focus, .field textarea:focus {
      border-color: rgba(51, 69, 213, 0.52);
      box-shadow: 0 0 0 4px rgba(51, 69, 213, 0.12);
    }

    .field textarea { min-height: 88px; resize: vertical; }

    .field .hint {
      font-size: 12px;
      color: var(--muted);
      margin-top: 2px;
    }

    .account-table-wrap, .detail-table-wrap {
      overflow: auto;
      border-radius: 16px;
      border: 1px solid var(--border);
      background: white;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      min-width: 980px;
      background: white;
    }

    th, td {
      padding: 12px 12px;
      border-bottom: 1px solid #e7ecf3;
      text-align: left;
      font-size: 13px;
      vertical-align: middle;
    }

    th {
      position: sticky;
      top: 0;
      z-index: 1;
      background: linear-gradient(180deg, #f8fbff, #f1f5fa);
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-size: 11px;
    }

    td input, td select {
      width: 100%;
      padding: 8px 10px;
      border: 1px solid var(--border);
      border-radius: 10px;
      background: #fff;
      min-width: 90px;
    }

    .stack {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .metrics {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 14px;
    }

    .metric-card {
      border-radius: 18px;
      padding: 16px 16px 14px;
      background: linear-gradient(180deg, #ffffff, #fbfcfe);
    }

    .metric-card .eyebrow {
      font-size: 11px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      font-weight: 700;
      margin-bottom: 6px;
    }

    .metric-card .big {
      font-size: 28px;
      line-height: 1;
      letter-spacing: -0.04em;
      font-weight: 700;
      color: var(--ink);
    }

    .metric-card .delta {
      margin-top: 8px;
      font-size: 12px;
      color: var(--muted);
    }

    .compare-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 14px;
    }

    .state-card {
      border-radius: 18px;
      padding: 18px 18px 16px;
      border: 1px solid rgba(51, 69, 213, 0.14);
      background: linear-gradient(180deg, #ffffff, #f6f9ff);
      box-shadow: var(--shadow);
    }

    .state-card.is-best {
      background: linear-gradient(180deg, #f7fbff, #edf3ff);
      border-color: rgba(51, 69, 213, 0.3);
      box-shadow: 0 16px 32px rgba(51, 69, 213, 0.12);
    }

    .state-card h3 {
      margin: 0;
      font-size: 24px;
      letter-spacing: -0.03em;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 10px;
      border-radius: 999px;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      font-weight: 700;
      background: #f0f5ff;
      color: var(--blue);
    }

    .state-stats {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      margin-top: 14px;
    }

    .stat-box {
      padding: 12px;
      border-radius: 14px;
      background: white;
      border: 1px solid #e5ecfb;
    }

    .stat-box .k {
      font-size: 11px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 4px;
    }

    .stat-box .v {
      font-size: 20px;
      font-weight: 700;
      color: var(--ink);
      letter-spacing: -0.03em;
    }

    .callout {
      margin-top: 12px;
      padding: 12px;
      border-radius: 14px;
      background: rgba(51, 69, 213, 0.07);
      color: #2c387a;
      font-size: 13px;
      line-height: 1.4;
    }

    .warning-chip {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 5px 9px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
      margin-right: 6px;
      margin-bottom: 6px;
    }

    .warning-chip.warn { background: #fff7e9; color: var(--warn); }
    .warning-chip.danger { background: #fff0f1; color: var(--danger); }
    .warning-chip.good { background: #eefcf5; color: var(--good); }

    .chart-card, .table-card, .insight-card {
      border-radius: 20px;
      padding: 16px;
    }

    .chart-controls, .details-toolbar {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      align-items: center;
      margin-bottom: 12px;
    }

    .chart-wrap {
      background: linear-gradient(180deg, #ffffff, #fbfcfe);
      border-radius: 18px;
      border: 1px solid var(--border);
      padding: 16px;
    }

    .chart-title {
      margin: 0 0 6px;
      font-size: 18px;
      letter-spacing: -0.02em;
    }

    .chart-subtitle {
      color: var(--muted);
      font-size: 13px;
      margin-bottom: 10px;
    }

    .chart-host {
      position: relative;
      width: 100%;
      min-height: 320px;
      border-radius: 16px;
      background: linear-gradient(180deg, #ffffff, #f8fbff);
      overflow: hidden;
      border: 1px solid #e6edf9;
    }

    .chart-host svg {
      display: block;
      width: 100%;
      height: 100%;
      min-height: 320px;
    }

    .chart-legend {
      display: flex;
      flex-wrap: wrap;
      gap: 10px 16px;
      font-size: 12px;
      margin-top: 12px;
      color: var(--muted);
    }

    .legend-item {
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .legend-swatch {
      width: 12px;
      height: 12px;
      border-radius: 999px;
      display: inline-block;
    }

    .notes {
      font-size: 12px;
      color: var(--muted);
      line-height: 1.5;
    }

    .insight-list {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .insight-item {
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 14px;
      background: linear-gradient(180deg, #fff, #fcfdff);
    }

    .insight-item h4 {
      margin: 0 0 6px;
      font-size: 16px;
      letter-spacing: -0.02em;
    }

    .insight-item p {
      margin: 0;
      font-size: 13px;
      color: var(--muted);
      line-height: 1.5;
    }

    .text-right { text-align: right; }
    .muted { color: var(--muted); }
    .mono { font-variant-numeric: tabular-nums; }

    .pill-select {
      display: inline-flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .pill-select button {
      border: 1px solid var(--border);
      background: white;
      color: var(--muted);
      padding: 8px 12px;
      border-radius: 999px;
      cursor: pointer;
      font-weight: 600;
    }

    .pill-select button.active {
      background: var(--blue-3);
      color: var(--blue);
      border-color: rgba(51, 69, 213, 0.28);
    }

    .footer-note {
      padding: 14px 2px 0;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.5;
    }


    .runtime-banner {
      margin-top: -4px;
      border-radius: 14px;
      border: 1px solid #ffd9df;
      background: #fff5f7;
      color: #8d2340;
      padding: 12px 14px;
      font-size: 13px;
      box-shadow: var(--shadow);
    }

    .runtime-banner.info {
      border-color: #d9e5ff;
      background: #f5f8ff;
      color: #2441ff;
    }

    .mini-badge-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 12px;
    }

    @media (max-width: 1240px) {
      .page { grid-template-columns: 1fr; }
      .sidebar { min-height: unset; }
      .metrics { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .compare-grid, .grid-3, .insight-list { grid-template-columns: 1fr; }
    }

    @media (max-width: 860px) {
      .page { width: min(100vw - 18px, 1560px); margin-top: 10px; }
      .hero h1 { font-size: 30px; }
      .grid-2, .field-grid, .metrics { grid-template-columns: 1fr; }
      .topbar { padding: 12px 16px; }
      .nav-links { justify-content: flex-start; }
    }
  </style>
</head>
<body>
  <div class="app-shell">
    <header class="topbar">
      <div class="brand">
        <div class="brand-lockup">JayTeeSF</div>
        <div class="brand-sub">
          <span class="primary" id="brandPrimary">James Sample</span>
          <span class="secondary" id="brandSecondary">Tammy Sample</span>
        </div>
      </div>
      <nav class="nav-links" aria-label="Primary">
        <span>Dashboard</span>
        <span>Investment</span>
        <span>Retirement</span>
        <span>Insurance</span>
        <span>Education</span>
        <span class="active">Tax</span>
        <span>Estate</span>
        <span>Profile</span>
      </nav>
    </header>

    <main class="page">
      <aside class="sidebar">
        <div class="sidebar-header">
          <div class="label">Scenario net worth</div>
          <div class="value mono" id="netWorthValue">$0</div>
          <div class="sub" id="taxBasisSubline"></div>
        </div>
        <ul class="bucket-list" id="bucketList"></ul>
        <div class="account-mini-list" id="accountMiniList"></div>
      </aside>

      <section class="content">
        <div class="hero">
          <div class="hero-top">
            <div>
              <h1>Retirement Scenario Lab</h1>
              <p>
                A single-file planning lab inspired by the RightCapital tax-strategy workflow. Model Roth conversions,
                RMD pressure, widow’s trap risk, and relocation trade-offs across California, Texas, and Georgia using
                one snapshot of your household balance sheet.
              </p>
            </div>
            <div class="hero-actions">
              <button class="btn btn-primary" id="recalculateBtn">Recalculate</button>
              <button class="btn btn-secondary" id="loadSampleBtn">Load sample</button>
              <button class="btn btn-secondary" id="exportJsonBtn">Export scenario</button>
              <button class="btn btn-secondary" id="importJsonBtn">Import scenario</button>
              <button class="btn btn-secondary" id="exportTaxJsonBtn">Export tax JSON</button>
              <button class="btn btn-secondary" id="importTaxJsonBtn">Import tax JSON</button>
              <input id="importFileInput" type="file" accept="application/json" hidden />
              <input id="importTaxFileInput" type="file" accept="application/json" hidden />
            </div>
          </div>
        </div>

        <div class="runtime-banner" id="runtimeBanner" hidden></div>

        <ul class="tabs" id="tabs">
          <li><button class="tab-button active" data-tab="inputs">Inputs</button></li>
          <li><button class="tab-button" data-tab="comparison">Comparison</button></li>
          <li><button class="tab-button" data-tab="details">Details</button></li>
          <li><button class="tab-button" data-tab="strategy">Strategy notes</button></li>
        </ul>

        <div class="tab-panel active" id="tab-inputs">
          <div class="grid-2">
            <article class="section-card">
              <div class="section-title">
                <div>
                  <h2>Household</h2>
                  <p>Core demographic assumptions and spending targets.</p>
                </div>
              </div>
              <div class="field-grid" id="householdFields"></div>
            </article>

            <article class="section-card">
              <div class="section-title">
                <div>
                  <h2>Strategy controls</h2>
                  <p>Roth conversion rules, return assumptions, and detail view.</p>
                </div>
              </div>
              <div class="field-grid" id="strategyFields"></div>
            </article>
          </div>

          <article class="section-card">
            <div class="section-title">
              <div>
                <h2>Accounts</h2>
                <p>Enter a current snapshot. Transactions are optional unless you want deeper spending calibration.</p>
              </div>
              <div>
                <button class="btn btn-ghost btn-sm" id="addAccountBtn">Add account</button>
              </div>
            </div>
            <div class="account-table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Account name</th>
                    <th>Owner</th>
                    <th>Type</th>
                    <th class="text-right">Balance</th>
                    <th class="text-right">Cost basis</th>
                    <th class="text-right">Growth return</th>
                    <th class="text-right">Dividend yield</th>
                    <th>Notes</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody id="accountsBody"></tbody>
              </table>
            </div>
            <div class="footer-note">
              Import format is simple JSON. A server-side Monarch adapter can emit the same schema by mapping accounts into
              <code>checking</code>, <code>taxable</code>, <code>ira</code>, and <code>roth</code> buckets and carrying cost basis for taxable assets.
            </div>
          </article>
        </div>

        <div class="tab-panel" id="tab-comparison">
          <section class="stack">
            <div class="metrics" id="headlineMetrics"></div>
            <div class="compare-grid" id="stateCompareGrid"></div>
          </section>

          <article class="chart-card">
            <div class="section-title">
              <div>
                <h3>Portfolio ending value by state</h3>
                <p>Annual ending total wealth after taxes, withdrawals, and Medicare premiums.</p>
              </div>
            </div>
            <div class="chart-wrap">
              <div class="chart-host" id="portfolioChart"></div>
              <div class="chart-legend" id="portfolioLegend"></div>
            </div>
          </article>

          <article class="chart-card">
            <div class="section-title">
              <div>
                <h3>Annual federal + state tax + IRMAA</h3>
                <p>Use this to spot widow’s trap years, conversion spikes, and RMD cliffs.</p>
              </div>
            </div>
            <div class="chart-controls">
              <div class="pill-select" id="taxChartStatePills"></div>
            </div>
            <div class="chart-wrap">
              <div class="chart-host" id="taxChart"></div>
              <div class="chart-legend" id="taxLegend"></div>
            </div>
          </article>
        </div>

        <div class="tab-panel" id="tab-details">
          <article class="table-card">
            <div class="section-title">
              <div>
                <h3>Projection details</h3>
                <p>Year-by-year distributions, conversions, taxes, RMDs, Medicare premiums, and end balances.</p>
              </div>
            </div>
            <div class="details-toolbar">
              <div class="pill-select" id="detailStatePills"></div>
            </div>
            <div class="detail-table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Year</th>
                    <th>Age</th>
                    <th>Filing</th>
                    <th class="text-right">Expenses</th>
                    <th class="text-right">SS income</th>
                    <th class="text-right">RMD</th>
                    <th class="text-right">Roth conv.</th>
                    <th class="text-right">Taxable sales</th>
                    <th class="text-right">IRA spend</th>
                    <th class="text-right">Federal tax</th>
                    <th class="text-right">State tax</th>
                    <th class="text-right">IRMAA</th>
                    <th class="text-right">Ending NW</th>
