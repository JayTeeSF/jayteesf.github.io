    function renderStrategyPanel() {
      const stateEntries = Object.values(projectionCache);
      const warnings = stateEntries.flatMap(entry => entry.alerts.map(alert => ({ ...alert, stateCode: entry.stateCode })));
      document.getElementById("warningChips").innerHTML = warnings.map(alert => `<span class="warning-chip ${alert.type}">${alert.stateCode}: ${alert.title}</span>`).join("");

      const defaultsNote = `
        <div><strong>Timing assumptions.</strong> Expenses are treated as monthly living draws, dividends are smoothed through the year, RMDs are spread through the year with a December true-up, and Roth conversions default to a late-year bracket-fill posture.</div>
        <div style="margin-top:10px;"><strong>Withdrawal order.</strong> Cash first, then taxable lots with the lowest embedded gain ratio, then mandatory RMDs, then additional IRA withdrawals, with Roth assets kept as the last bucket.</div>
        <div style="margin-top:10px;"><strong>Widow transition.</strong> After the first death the model flips from MFJ to Single, applies the survivor spending ratio, keeps the higher Social Security check, and keeps IRMAA on the survivor using single thresholds.</div>
        <div style="margin-top:10px;"><strong>State detail.</strong> California taxes capital gains as ordinary income and excludes Social Security. Texas has no personal income tax. Georgia uses a flat rate with a retirement-income exclusion by age.</div>
      `;
      document.getElementById("defaultsNote").innerHTML = defaultsNote;

      const best = [...stateEntries].sort((a, b) => b.endingNetWorth - a.endingNetWorth)[0];
