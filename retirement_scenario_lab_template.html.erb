    function buildLineChart(series, { valueFormatter }) {
      const sanitized = series.map(item => ({ ...item, points: (item.points || []).filter(point => Number.isFinite(point.x) && Number.isFinite(point.y)) })).filter(item => item.points.length);
      if (!sanitized.length) {
        return `<div style="display:flex;align-items:center;justify-content:center;height:320px;color:#7f8a9a;font-size:14px;">No chartable data yet.</div>`;
      }
      series = sanitized;
      const width = 920;
      const height = 320;
      const margin = { top: 18, right: 28, bottom: 38, left: 70 };
      const allPoints = series.flatMap(item => item.points);
      const minX = Math.min(...allPoints.map(point => point.x));
      const maxX = Math.max(...allPoints.map(point => point.x));
      const maxY = Math.max(...allPoints.map(point => point.y), 1);
      const innerWidth = width - margin.left - margin.right;
      const innerHeight = height - margin.top - margin.bottom;
      const x = year => margin.left + ((year - minX) / Math.max(1, maxX - minX)) * innerWidth;
      const y = value => margin.top + innerHeight - (value / maxY) * innerHeight;
      const gridLines = Array.from({ length: 5 }, (_, index) => index).map(index => {
        const value = maxY * (index / 4);
        const yPos = y(value);
        return `<g><line x1="${margin.left}" x2="${width - margin.right}" y1="${yPos}" y2="${yPos}" stroke="#e7edf7" stroke-width="1" />
                <text x="${margin.left - 12}" y="${yPos + 4}" font-size="11" fill="#7f8a9a" text-anchor="end">${escapeHtml(valueFormatter(value))}</text></g>`;
      }).join("");

      const xLabels = Array.from({ length: Math.min(6, maxX - minX + 1) }, (_, index) => Math.round(minX + (index * (maxX - minX)) / Math.max(1, Math.min(5, maxX - minX)))).map(year => `
        <g>
          <line x1="${x(year)}" x2="${x(year)}" y1="${margin.top}" y2="${height - margin.bottom}" stroke="#f1f4f9" stroke-width="1" />
          <text x="${x(year)}" y="${height - 14}" font-size="11" fill="#7f8a9a" text-anchor="middle">${year}</text>
        </g>
      `).join("");

      const lines = series.map(item => {
        const path = item.points.map((point, index) => `${index === 0 ? "M" : "L"}${x(point.x)} ${y(point.y)}`).join(" ");
        return `
          <path d="${path}" fill="none" stroke="${item.color}" stroke-width="3" stroke-linejoin="round" stroke-linecap="round" />
          ${item.points.map(point => `<circle cx="${x(point.x)}" cy="${y(point.y)}" r="3.5" fill="${item.color}" />`).join("")}
        `;
      }).join("");

      return `
        <svg viewBox="0 0 ${width} ${height}" preserveAspectRatio="none" role="img" aria-label="Line chart">
          <rect width="100%" height="100%" fill="url(#panelGrad)" rx="14"></rect>
          <defs>
            <linearGradient id="panelGrad" x1="0" x2="0" y1="0" y2="1">
              <stop offset="0%" stop-color="#ffffff" />
              <stop offset="100%" stop-color="#f8fbff" />
            </linearGradient>
          </defs>
          ${gridLines}
          ${xLabels}
          ${lines}
        </svg>
      `;
    }

    function attachGlobalHandlers() {
      document.querySelectorAll(".tab-button").forEach(button => {
        button.addEventListener("click", () => {
          document.querySelectorAll(".tab-button").forEach(el => el.classList.remove("active"));
          document.querySelectorAll(".tab-panel").forEach(el => el.classList.remove("active"));
          button.classList.add("active");
          document.getElementById(`tab-${button.dataset.tab}`).classList.add("active");
        });
      });

      document.getElementById("recalculateBtn").addEventListener("click", computeAndRender);
      document.getElementById("loadSampleBtn").addEventListener("click", () => {
        appState = deepClone(SAMPLE_SCENARIO);
        bootstrap();
      });
      document.getElementById("addAccountBtn").addEventListener("click", () => {
        appState.accounts.push({
          name: "New account",
          owner: "joint",
          type: "taxable",
          balance: 0,
          costBasis: 0,
          annualReturn: appState.household.taxableReturn,
          dividendYield: 0.015,
          notes: ""
        });
        renderAccountsTable();
        renderSummarySidebar();
        computeAndRender();
      });
      document.getElementById("exportJsonBtn").addEventListener("click", exportScenarioJson);
      document.getElementById("importJsonBtn").addEventListener("click", () => document.getElementById("importFileInput").click());
      document.getElementById("importFileInput").addEventListener("change", importScenarioJson);
      document.getElementById("exportTaxJsonBtn").addEventListener("click", exportTaxJson);
      document.getElementById("importTaxJsonBtn").addEventListener("click", () => document.getElementById("importTaxFileInput").click());
      document.getElementById("importTaxFileInput").addEventListener("change", importTaxJson);
    }

    function exportScenarioJson() {
      const blob = new Blob([JSON.stringify(appState, null, 2)], { type: "application/json" });
      const url = URL.createObjectURL(blob);
      const link = document.createElement("a");
      link.href = url;
      link.download = "retirement_scenario.json";
      link.click();
      URL.revokeObjectURL(url);
    }

    function exportTaxJson() {
      const blob = new Blob([JSON.stringify(taxData, null, 2)], { type: "application/json" });
      const url = URL.createObjectURL(blob);
      const link = document.createElement("a");
      link.href = url;
      link.download = `retirement_tax_tables_${taxData.basisTaxYear || "custom"}.json`;
      link.click();
      URL.revokeObjectURL(url);
    }

    function importTaxJson(event) {
      const [file] = event.target.files || [];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = loadEvent => {
        try {
          const parsed = JSON.parse(loadEvent.target.result);
          if (!parsed.federal || !parsed.states) throw new Error("Expected federal + states sections.");
          taxData = parsed;
          refreshTaxBasisLabel();
          computeAndRender();
          setRuntimeBanner(`Loaded tax tables for basis year ${taxData.basisTaxYear || "custom"}.`, "info");
        } catch (error) {
          window.alert(`Could not import tax JSON: ${error.message}`);
        }
      };
      reader.readAsText(file);
      event.target.value = "";
    }

    function importScenarioJson(event) {
      const [file] = event.target.files || [];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = loadEvent => {
        try {
          const parsed = JSON.parse(loadEvent.target.result);
          if (!parsed.household || !Array.isArray(parsed.accounts)) throw new Error("Expected household + accounts.");
          appState = parsed;
          bootstrap();
        } catch (error) {
          window.alert(`Could not import JSON: ${error.message}`);
        }
      };
      reader.readAsText(file);
      event.target.value = "";
    }

    function bootstrap() {
      updateBrand();
      refreshTaxBasisLabel();
      setupFields();
      renderAccountsTable();
      renderSummarySidebar();
      detailState = appState.household.residenceStates?.[0] || "CA";
      taxChartState = detailState;
      computeAndRender();
    }

    document.addEventListener("DOMContentLoaded", () => {
      attachGlobalHandlers();
      bootstrap();
    });
  </script>
</body>
</html>
