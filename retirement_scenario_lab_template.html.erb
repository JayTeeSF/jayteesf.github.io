  <script id="embedded-tax-data" type="application/json"><%= embedded_tax_data_json %></script>
  <script id="embedded-defaults" type="application/json"><%= embedded_defaults_json %></script>
  <script id="embedded-sample-scenario" type="application/json"><%= embedded_sample_scenario_json %></script>

  <script>
    const EMBEDDED_TAX_DATA = JSON.parse(document.getElementById("embedded-tax-data").textContent);
    const EMBEDDED_DEFAULTS = JSON.parse(document.getElementById("embedded-defaults").textContent);
    const EMBEDDED_SAMPLE_SCENARIO = JSON.parse(document.getElementById("embedded-sample-scenario").textContent);

    let taxData = EMBEDDED_TAX_DATA;
    let plannerDefaults = EMBEDDED_DEFAULTS;
    const SAMPLE_SCENARIO = EMBEDDED_SAMPLE_SCENARIO;

    const FIELD_CONFIG = {
      household: [
        ["spouse1Name", "Spouse 1 name", "text"],
        ["spouse2Name", "Spouse 2 name", "text"],
        ["currentYear", "Start year", "number"],
        ["annualSpending", "Annual spending", "currency"],
        ["spouse1CurrentAge", "Spouse 1 current age", "number"],
        ["spouse2CurrentAge", "Spouse 2 current age", "number"],
        ["spouse1RetireAge", "Spouse 1 retire age", "number"],
        ["spouse2RetireAge", "Spouse 2 retire age", "number"],
        ["spouse1DeathAge", "Spouse 1 death age", "number"],
        ["spouse2DeathAge", "Spouse 2 death age", "number"],
        ["spouse1SocialSecurityAge", "Spouse 1 SS age", "number"],
        ["spouse2SocialSecurityAge", "Spouse 2 SS age", "number"],
        ["spouse1SocialSecurityAnnual", "Spouse 1 SS annual", "currency"],
        ["spouse2SocialSecurityAnnual", "Spouse 2 SS annual", "currency"],
        ["pensionAnnual", "Pension / annuity annual", "currency"],
        ["survivorSpendingRatio", "Survivor spending ratio", "percent"],
        ["inflationRate", "Inflation", "percent"],
        ["socialSecurityCOLA", "SS COLA", "percent"],
        ["cashReturn", "Cash return", "percent"],
        ["taxableReturn", "Taxable return", "percent"],
        ["retirementReturn", "Retirement return", "percent"]
      ],
      strategy: [
        ["rothStrategy", "Roth strategy", "select", [
          ["none", "None"],
          ["fill_bracket", "Fill federal bracket"],
          ["fill_bracket_avoid_irmaa", "Fill bracket, avoid next IRMAA tier"],
          ["fixed", "Fixed annual conversion"]
        ]],
        ["targetBracketRate", "Target federal bracket", "select", [
          [0.12, "12%"], [0.22, "22%"], [0.24, "24%"], [0.32, "32%"]
        ]],
        ["fixedConversionAmount", "Fixed annual conversion", "currency"],
        ["notes", "Scenario notes", "textarea"]
      ]
    };

    const STATE_COLORS = { CA: "#3345d5", TX: "#1ba76f", GA: "#9b6bff" };
    const TAX_SERIES_COLORS = { federal: "#3345d5", state: "#1ba76f", irmaa: "#f3a400" };

    let appState = deepClone(SAMPLE_SCENARIO);
    let projectionCache = {};
    let detailState = "CA";
    let taxChartState = "CA";

    function deepClone(value) {
      return JSON.parse(JSON.stringify(value));
    }


    function setRuntimeBanner(message = "", type = "error") {
      const el = document.getElementById("runtimeBanner");
      if (!el) return;
      if (!message) {
        el.hidden = true;
        el.textContent = "";
        el.className = "runtime-banner";
        return;
      }
      el.hidden = false;
      el.textContent = message;
      el.className = `runtime-banner ${type}`;
    }

    function refreshTaxBasisLabel() {
      const basisYear = taxData?.basisTaxYear || "custom";
      const stateNames = (appState?.household?.residenceStates || ["CA", "TX", "GA"]).map(code => taxData?.states?.[code]?.name || code).join(", ");
      const label = document.getElementById("taxBasisSubline");
      if (label) label.textContent = `Tax basis year ${basisYear}. Replaceable via tax JSON import. Comparing ${stateNames}.`;
    }

    function currency(value, digits = 0) {
      return new Intl.NumberFormat("en-US", {
        style: "currency",
        currency: "USD",
        maximumFractionDigits: digits,
        minimumFractionDigits: digits
      }).format(Number.isFinite(value) ? value : 0);
    }

    function percent(value, digits = 1) {
      return `${(value * 100).toFixed(digits)}%`;
    }

    function numberFormat(value, digits = 0) {
      return new Intl.NumberFormat("en-US", { maximumFractionDigits: digits, minimumFractionDigits: digits }).format(Number.isFinite(value) ? value : 0);
    }

    function setupFields() {
      const householdFields = document.getElementById("householdFields");
      const strategyFields = document.getElementById("strategyFields");
      householdFields.innerHTML = "";
      strategyFields.innerHTML = "";

      FIELD_CONFIG.household.forEach(config => householdFields.appendChild(buildField(config, appState.household)));
      FIELD_CONFIG.strategy.forEach(config => strategyFields.appendChild(buildField(config, appState.household)));
    }

    function buildField([key, label, type, options], target) {
      const wrapper = document.createElement("div");
      wrapper.className = "field";
      const labelEl = document.createElement("label");
      labelEl.textContent = label;
      labelEl.setAttribute("for", `field-${key}`);
      wrapper.appendChild(labelEl);

      let input;
      if (type === "select") {
        input = document.createElement("select");
        options.forEach(([value, title]) => {
          const option = document.createElement("option");
          option.value = String(value);
          option.textContent = title;
          if (String(target[key]) === String(value)) option.selected = true;
          input.appendChild(option);
        });
      } else if (type === "textarea") {
        input = document.createElement("textarea");
        input.value = target[key] ?? "";
      } else {
        input = document.createElement("input");
        input.type = type === "text" ? "text" : "number";
        input.step = type === "number" ? "1" : "0.001";
        input.value = target[key] ?? "";
      }
      input.id = `field-${key}`;
      input.dataset.key = key;
      input.dataset.type = type;
      input.addEventListener("change", event => updateHouseholdField(event.target));
      wrapper.appendChild(input);

      if (key === "survivorSpendingRatio") {
        wrapper.appendChild(buildHint("0.78 means the surviving spouse keeps 78% of household spending after the first death."));
      }
      if (key === "targetBracketRate") {
        wrapper.appendChild(buildHint("Conversion strategy fills the top of this bracket unless IRMAA avoidance is enabled."));
      }
      return wrapper;
    }

    function buildHint(text) {
      const div = document.createElement("div");
      div.className = "hint";
      div.textContent = text;
      return div;
    }

    function updateHouseholdField(input) {
      const key = input.dataset.key;
      const type = input.dataset.type;
      let value;
      if (type === "text" || type === "textarea") {
        value = input.value;
      } else if (type === "select") {
        value = input.value;
        if (["targetBracketRate"].includes(key)) value = Number(value);
      } else {
        value = Number(input.value || 0);
      }
      appState.household[key] = value;
      renderSummarySidebar();
      if (key === "spouse1Name" || key === "spouse2Name") updateBrand();
      computeAndRender();
    }

    function renderAccountsTable() {
      const tbody = document.getElementById("accountsBody");
      tbody.innerHTML = "";
      appState.accounts.forEach((account, index) => {
        const tr = document.createElement("tr");
        tr.innerHTML = `
          <td><input data-index="${index}" data-field="name" value="${escapeHtml(account.name)}" /></td>
          <td>
            <select data-index="${index}" data-field="owner">
              ${optionHtml(account.owner, [
                ["joint", "Joint"],
                ["spouse1", "Spouse 1"],
                ["spouse2", "Spouse 2"]
              ])}
            </select>
          </td>
          <td>
            <select data-index="${index}" data-field="type">
              ${optionHtml(account.type, [
                ["checking", "Checking / cash"],
                ["taxable", "Taxable"],
                ["ira", "Traditional IRA / 401k"],
                ["roth", "Roth"]
              ])}
            </select>
          </td>
          <td><input class="text-right" data-index="${index}" data-field="balance" type="number" step="0.01" value="${account.balance}" /></td>
          <td><input class="text-right" data-index="${index}" data-field="costBasis" type="number" step="0.01" value="${account.costBasis}" /></td>
          <td><input class="text-right" data-index="${index}" data-field="annualReturn" type="number" step="0.001" value="${account.annualReturn}" /></td>
          <td><input class="text-right" data-index="${index}" data-field="dividendYield" type="number" step="0.001" value="${account.dividendYield}" /></td>
          <td><input data-index="${index}" data-field="notes" value="${escapeHtml(account.notes || "")}" /></td>
          <td><button class="btn btn-danger btn-sm" data-remove="${index}">Delete</button></td>
        `;
        tbody.appendChild(tr);
      });

      tbody.querySelectorAll("input, select").forEach(el => {
        el.addEventListener("change", event => {
          const index = Number(event.target.dataset.index);
          const field = event.target.dataset.field;
          let value = event.target.value;
          if (["balance", "costBasis", "annualReturn", "dividendYield"].includes(field)) value = Number(value || 0);
          appState.accounts[index][field] = value;
          renderSummarySidebar();
          computeAndRender();
        });
      });

      tbody.querySelectorAll("button[data-remove]").forEach(btn => {
        btn.addEventListener("click", () => {
          const index = Number(btn.dataset.remove);
          appState.accounts.splice(index, 1);
          renderAccountsTable();
          renderSummarySidebar();
          computeAndRender();
        });
      });
    }

    function optionHtml(current, items) {
      return items.map(([value, label]) => `<option value="${value}" ${String(current) === String(value) ? "selected" : ""}>${label}</option>`).join("");
    }

    function escapeHtml(value) {
      return String(value ?? "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/\"/g, "&quot;")
        .replace(/'/g, "&#039;");
    }

    function renderSummarySidebar() {
      const totals = summarizeAccounts(appState.accounts);
      document.getElementById("netWorthValue").textContent = currency(totals.total);
      document.getElementById("bucketList").innerHTML = `
        ${bucketRowHtml("Bank", totals.checking, totals.counts.checking)}
        ${bucketRowHtml("Taxable", totals.taxable, totals.counts.taxable)}
        ${bucketRowHtml("Tax deferred", totals.ira, totals.counts.ira)}
        ${bucketRowHtml("Roth", totals.roth, totals.counts.roth)}
      `;
      document.getElementById("accountMiniList").innerHTML = appState.accounts.map(account => `
        <div class="account-mini">
          <div class="title"><span>${escapeHtml(account.name)}</span><span class="mono">${currency(account.balance)}</span></div>
          <div class="meta">
            <span>${account.owner === "joint" ? "Joint" : account.owner === "spouse1" ? appState.household.spouse1Name : appState.household.spouse2Name}</span>
            <span>•</span>
            <span>${labelForAccountType(account.type)}</span>
            ${account.type === "taxable" ? `<span>• Basis ${currency(account.costBasis)}</span>` : ""}
          </div>
        </div>
      `).join("");
    }

    function bucketRowHtml(label, amount, count) {
      return `
        <li class="bucket-row">
          <div class="bucket-name">${label}</div>
          <div class="bucket-total mono">${currency(amount)}</div>
          <div class="bucket-count">${count} account${count === 1 ? "" : "s"}</div>
        </li>
      `;
    }

    function labelForAccountType(type) {
      switch (type) {
        case "checking": return "Checking / cash";
        case "taxable": return "Taxable";
        case "ira": return "Traditional IRA / 401k";
        case "roth": return "Roth";
        default: return type;
      }
    }

    function summarizeAccounts(accounts) {
      const summary = {
        total: 0,
        checking: 0,
        taxable: 0,
        ira: 0,
        roth: 0,
        counts: { checking: 0, taxable: 0, ira: 0, roth: 0 }
      };
      accounts.forEach(account => {
        summary.total += account.balance;
        summary[account.type] += account.balance;
        summary.counts[account.type] += 1;
      });
      return summary;
    }

    function updateBrand() {
      document.getElementById("brandPrimary").textContent = appState.household.spouse1Name || "Spouse 1";
      document.getElementById("brandSecondary").textContent = appState.household.spouse2Name || "Spouse 2";
    }

    function computeAndRender() {
      try {
        setRuntimeBanner("");
        projectionCache = {};
        const states = (appState.household.residenceStates || ["CA", "TX", "GA"]).filter(stateCode => taxData.states?.[stateCode]);
        states.forEach(stateCode => {
          projectionCache[stateCode] = projectScenario(appState, stateCode);
        });
        renderHeadlineMetrics();
        renderStateComparison();
        renderPortfolioChart();
        renderTaxChart();
        renderDetailsTable();
        renderStrategyPanel();
      } catch (error) {
        console.error(error);
        setRuntimeBanner(`Projection failed: ${error.message}`);
      }
    }

    function projectScenario(state, stateCode) {
      const household = deepClone(state.household);
      const accounts = deepClone(state.accounts);
      const history = [];
      const magiHistory = {};
      const startYear = household.currentYear;
      const endYear = Math.max(startYear + 30, startYear + Math.max(
        household.spouse1DeathAge - household.spouse1CurrentAge,
        household.spouse2DeathAge - household.spouse2CurrentAge
      ) + 2);

      for (let year = startYear; year <= endYear; year += 1) {
        const ages = getAges(household, year);
        const alive1 = ages.spouse1 <= household.spouse1DeathAge;
        const alive2 = ages.spouse2 <= household.spouse2DeathAge;
        if (!alive1 && !alive2) break;

        const firstDeathOccurred = !(alive1 && alive2);
        const filingStatus = alive1 && alive2 ? "married_filing_jointly" : "single";
        const inflationFactor = Math.pow(1 + household.inflationRate, year - startYear);
        const survivorRatio = firstDeathOccurred ? household.survivorSpendingRatio : 1;
        const annualExpenses = household.annualSpending * inflationFactor * survivorRatio;

        const ssIncome = calcSocialSecurityIncome(household, ages, year, alive1, alive2, startYear);
        const pensionIncome = calcPensionIncome(household, year, alive1 || alive2, startYear);

        const taxableAccounts = accounts.filter(a => a.type === "taxable");
        const taxableDividendCash = taxableAccounts.reduce((sum, a) => sum + a.balance * (a.dividendYield || 0), 0);
        const qualifiedDividends = taxableDividendCash;
        const cashInterest = accounts.filter(a => a.type === "checking").reduce((sum, a) => sum + a.balance * (a.annualReturn || household.cashReturn), 0);
        const ordinaryInvestmentIncome = cashInterest;

        const rmdInfo = calcRmds(accounts, household, ages, year);
        applyRmds(accounts, rmdInfo.byAccount);

        const ordinaryBeforeConversion = pensionIncome + ordinaryInvestmentIncome + rmdInfo.total;
        const taxableSSBefore = calcTaxableSocialSecurity(ssIncome, ordinaryBeforeConversion, qualifiedDividends, filingStatus);
        const agiBeforeConversion = ordinaryBeforeConversion + taxableSSBefore + qualifiedDividends;

        const conversion = calcRothConversion({
          household,
          accounts,
          filingStatus,
          ages,
          year,
          ordinaryBeforeConversion,
          qualifiedDividends,
          ssIncome,
          agiBeforeConversion,
          stateCode
        });
        applyConversion(accounts, conversion.byAccount);

        let estimate = {
          taxableSales: 0,
          taxableRealizedGains: 0,
          iraSpending: 0,
          rothSpending: 0,
          cashSpent: 0,
          federalTax: 0,
          stateTax: 0,
          irmaa: calcIrmaaForYear(magiHistory, history, household, ages, year),
          ordinaryExtra: 0
        };

        for (let pass = 0; pass < 4; pass += 1) {
          const spendNeed = Math.max(0, annualExpenses + estimate.federalTax + estimate.stateTax + estimate.irmaa - (ssIncome + pensionIncome + taxableDividendCash + cashInterest + rmdInfo.total));
          const workingAccounts = deepClone(accounts);
          const withdrawal = fundSpendingNeed(workingAccounts, spendNeed, household, ages, year);

          const ordinaryIncome = pensionIncome + ordinaryInvestmentIncome + rmdInfo.total + conversion.total + withdrawal.iraSpending;
          const taxableSS = calcTaxableSocialSecurity(ssIncome, ordinaryIncome, qualifiedDividends + withdrawal.taxableRealizedGains, filingStatus);
          const agi = ordinaryIncome + taxableSS + qualifiedDividends + withdrawal.taxableRealizedGains;
          const federalTax = calcFederalTax(filingStatus, ordinaryIncome + taxableSS, qualifiedDividends + withdrawal.taxableRealizedGains, agi);
          const stateTax = calcStateTax(stateCode, filingStatus, ordinaryIncome, qualifiedDividends + withdrawal.taxableRealizedGains, ssIncome, ages, household);
          const irmaa = calcIrmaaForYear(magiHistory, history, household, ages, year);

          estimate = {
            ...withdrawal,
            federalTax,
            stateTax,
            irmaa,
            ordinaryExtra: withdrawal.iraSpending,
            taxableSS,
            agi
          };
        }

        const finalNeed = Math.max(0, annualExpenses + estimate.federalTax + estimate.stateTax + estimate.irmaa - (ssIncome + pensionIncome + taxableDividendCash + cashInterest + rmdInfo.total));
        const finalWithdrawal = fundSpendingNeed(accounts, finalNeed, household, ages, year);

        const finalOrdinaryIncome = pensionIncome + ordinaryInvestmentIncome + rmdInfo.total + conversion.total + finalWithdrawal.iraSpending;
        const finalTaxableSS = calcTaxableSocialSecurity(ssIncome, finalOrdinaryIncome, qualifiedDividends + finalWithdrawal.taxableRealizedGains, filingStatus);
        const finalAgi = finalOrdinaryIncome + finalTaxableSS + qualifiedDividends + finalWithdrawal.taxableRealizedGains;
        const federalTax = calcFederalTax(filingStatus, finalOrdinaryIncome + finalTaxableSS, qualifiedDividends + finalWithdrawal.taxableRealizedGains, finalAgi);
        const stateTax = calcStateTax(stateCode, filingStatus, finalOrdinaryIncome, qualifiedDividends + finalWithdrawal.taxableRealizedGains, ssIncome, ages, household);
        const irmaa = calcIrmaaForYear(magiHistory, history, household, ages, year);

        applyGrowth(accounts, household);

        const ending = summarizeAccounts(accounts);
        magiHistory[year] = { magi: finalAgi, filingStatus };

        history.push({
          year,
          ages: `${alive1 ? ages.spouse1 : "-"}/${alive2 ? ages.spouse2 : "-"}`,
          filingStatus,
          annualExpenses,
          ssIncome,
          pensionIncome,
          rmd: rmdInfo.total,
          rothConversion: conversion.total,
          taxableSales: finalWithdrawal.taxableSales,
          taxableRealizedGains: finalWithdrawal.taxableRealizedGains,
          iraSpending: finalWithdrawal.iraSpending,
          rothSpending: finalWithdrawal.rothSpending,
          cashSpent: finalWithdrawal.cashSpent,
          federalTax,
          stateTax,
          irmaa,
          agi: finalAgi,
          taxableSS: finalTaxableSS,
          ordinaryIncome: finalOrdinaryIncome,
          endingNetWorth: ending.total,
          endingBuckets: ending,
          marginalRate: marginalRateForIncome(filingStatus, Math.max(0, finalOrdinaryIncome + finalTaxableSS - taxData.federal.standardDeduction[filingStatus]))
        });
      }

      const totals = history.reduce((acc, row) => {
        acc.federalTax += row.federalTax;
        acc.stateTax += row.stateTax;
        acc.irmaa += row.irmaa;
        acc.conversions += row.rothConversion;
        acc.rmd += row.rmd;
        return acc;
      }, { federalTax: 0, stateTax: 0, irmaa: 0, conversions: 0, rmd: 0 });

      const alerts = findAlerts(history, household, stateCode);
      return { stateCode, history, totals, alerts, endingNetWorth: history.at(-1)?.endingNetWorth || 0 };
    }

    function getAges(household, year) {
      const offset = year - household.currentYear;
      return {
        spouse1: household.spouse1CurrentAge + offset,
        spouse2: household.spouse2CurrentAge + offset
      };
    }

    function calcSocialSecurityIncome(household, ages, year, alive1, alive2, startYear) {
      const colaFactor = Math.pow(1 + household.socialSecurityCOLA, year - startYear);
      const s1 = alive1 && ages.spouse1 >= household.spouse1SocialSecurityAge ? household.spouse1SocialSecurityAnnual * colaFactor : 0;
      const s2 = alive2 && ages.spouse2 >= household.spouse2SocialSecurityAge ? household.spouse2SocialSecurityAnnual * colaFactor : 0;
      if (alive1 && alive2) return s1 + s2;
      return Math.max(s1, s2, household.spouse1SocialSecurityAnnual * colaFactor, household.spouse2SocialSecurityAnnual * colaFactor) * (alive1 || alive2 ? 1 : 0);
    }

    function calcPensionIncome(household, year, anyoneAlive, startYear) {
      if (!anyoneAlive) return 0;
      return household.pensionAnnual * Math.pow(1 + household.inflationRate * 0.3, year - startYear);
    }

    function calcTaxableSocialSecurity(ssIncome, ordinaryIncomeExcludingSS, preferentialIncome, filingStatus) {
      if (ssIncome <= 0) return 0;
      const status = filingStatus === "married_filing_jointly" ? "married_filing_jointly" : "single";
      const base = taxData.federal.ssTaxation.base[status];
      const second = taxData.federal.ssTaxation.second[status];
      const fixedAdd = taxData.federal.ssTaxation.fixedAdd[status];
      const combined = ordinaryIncomeExcludingSS + preferentialIncome + 0.5 * ssIncome;
      if (combined <= base) return 0;
      if (combined <= second) return Math.min(0.5 * ssIncome, 0.5 * (combined - base));
      return Math.min(0.85 * ssIncome, 0.85 * (combined - second) + Math.min(fixedAdd, 0.5 * ssIncome));
    }

    function calcRmds(accounts, household, ages, year) {
      const result = { total: 0, byAccount: {} };
      accounts.forEach((account, index) => {
        if (account.type !== "ira") return;
        const ownerAge = account.owner === "spouse1" ? ages.spouse1 : account.owner === "spouse2" ? ages.spouse2 : Math.max(ages.spouse1, ages.spouse2);
        const ownerBirthYear = household.currentYear - (account.owner === "spouse1" ? household.spouse1CurrentAge : account.owner === "spouse2" ? household.spouse2CurrentAge : Math.max(household.spouse1CurrentAge, household.spouse2CurrentAge));
        const startAge = ownerBirthYear >= 1960 ? taxData.federal.rmd.startAge1960Plus : taxData.federal.rmd.startAgePre1960;
        if (ownerAge < startAge) return;
        const ageKey = Math.min(120, Math.max(73, ownerAge));
        const divisor = taxData.federal.rmd.divisors[ageKey] || 2;
        const rmd = Math.min(account.balance, account.balance / divisor);
        result.total += rmd;
        result.byAccount[index] = rmd;
      });
      return result;
    }

    function applyRmds(accounts, rmdByAccount) {
      Object.entries(rmdByAccount).forEach(([index, amount]) => {
        accounts[index].balance = Math.max(0, accounts[index].balance - amount);
      });
    }

    function calcRothConversion({ household, accounts, filingStatus, ages, ordinaryBeforeConversion, qualifiedDividends, ssIncome, agiBeforeConversion }) {
      const strategy = household.rothStrategy;
      const available = accounts.reduce((sum, account) => sum + (account.type === "ira" ? account.balance : 0), 0);
      if (!available || strategy === "none") return { total: 0, byAccount: {} };

      let desired = 0;
      if (strategy === "fixed") {
        desired = household.fixedConversionAmount || 0;
      } else {
        const taxableSS = calcTaxableSocialSecurity(ssIncome, ordinaryBeforeConversion, qualifiedDividends, filingStatus);
        const ordinaryTaxableBefore = Math.max(0, ordinaryBeforeConversion + taxableSS - taxData.federal.standardDeduction[filingStatus]);
        const targetTop = targetBracketUpperBound(filingStatus, household.targetBracketRate);
        const roomToBracket = Math.max(0, targetTop - ordinaryTaxableBefore);
        desired = roomToBracket;
        if (strategy === "fill_bracket_avoid_irmaa") {
          const nextIrmaa = nextIrmaaThreshold(filingStatus, agiBeforeConversion);
          desired = Math.min(desired, Math.max(0, nextIrmaa - agiBeforeConversion - 1000));
        }
      }

      desired = Math.max(0, Math.min(desired, available));
      const byAccount = {};
      if (desired === 0) return { total: 0, byAccount };

      const iraIndices = accounts.map((account, index) => [account, index]).filter(([account]) => account.type === "ira");
      let remaining = desired;
      iraIndices.forEach(([account, index], idx) => {
        const take = idx === iraIndices.length - 1 ? remaining : Math.min(remaining, desired * (account.balance / available));
        byAccount[index] = take;
        remaining -= take;
      });
      return { total: desired, byAccount };
    }

    function applyConversion(accounts, byAccount) {
      let converted = 0;
      Object.entries(byAccount).forEach(([index, amount]) => {
        accounts[index].balance = Math.max(0, accounts[index].balance - amount);
        converted += amount;
      });
      if (converted > 0) {
        const roth = accounts.find(account => account.type === "roth" && account.owner === "joint") || accounts.find(account => account.type === "roth");
        if (roth) {
          roth.balance += converted;
        } else {
          accounts.push({
            name: "Conversion Roth",
            owner: "joint",
            type: "roth",
            balance: converted,
            costBasis: 0,
            annualReturn: appState.household.retirementReturn,
            dividendYield: 0,
            notes: "Auto-created by Roth conversions"
          });
        }
      }
    }

    function fundSpendingNeed(accounts, amountNeeded) {
      const result = {
        taxableSales: 0,
        taxableRealizedGains: 0,
        iraSpending: 0,
        rothSpending: 0,
        cashSpent: 0
      };
      let remaining = Math.max(0, amountNeeded);

      const cashAccounts = accounts.filter(a => a.type === "checking");
      for (const account of cashAccounts) {
        if (remaining <= 0) break;
        const take = Math.min(account.balance, remaining);
        account.balance -= take;
        remaining -= take;
        result.cashSpent += take;
      }

      const taxableAccounts = accounts
        .map((account, index) => ({ account, index }))
        .filter(({ account }) => account.type === "taxable")
        .sort((a, b) => embeddedGainRatio(a.account) - embeddedGainRatio(b.account));
      for (const item of taxableAccounts) {
        if (remaining <= 0) break;
        const account = item.account;
        const take = Math.min(account.balance, remaining);
        const gainRatio = embeddedGainRatio(account);
        const realizedGain = take * gainRatio;
        const basisReduction = take - realizedGain;
        account.balance -= take;
        account.costBasis = Math.max(0, account.costBasis - basisReduction);
        remaining -= take;
        result.taxableSales += take;
        result.taxableRealizedGains += realizedGain;
      }

      const iraAccounts = accounts.filter(a => a.type === "ira");
      for (const account of iraAccounts) {
        if (remaining <= 0) break;
        const take = Math.min(account.balance, remaining);
        account.balance -= take;
        remaining -= take;
        result.iraSpending += take;
      }

      const rothAccounts = accounts.filter(a => a.type === "roth");
      for (const account of rothAccounts) {
        if (remaining <= 0) break;
        const take = Math.min(account.balance, remaining);
        account.balance -= take;
        remaining -= take;
        result.rothSpending += take;
      }

      return result;
    }

    function embeddedGainRatio(account) {
      if (!account.balance) return 0;
      return Math.max(0, (account.balance - (account.costBasis || 0)) / account.balance);
    }

    function applyGrowth(accounts, household) {
      accounts.forEach(account => {
        const rate = Number.isFinite(account.annualReturn) ? account.annualReturn : (
          account.type === "checking" ? household.cashReturn : account.type === "taxable" ? household.taxableReturn : household.retirementReturn
        );
        account.balance *= (1 + rate);
      });
    }

    function calcFederalTax(filingStatus, ordinaryIncomeInclTaxableSS, preferentialIncome, agi) {
      const standardDeduction = taxData.federal.standardDeduction[filingStatus];
      const taxableOrdinary = Math.max(0, ordinaryIncomeInclTaxableSS - standardDeduction);
      const taxableTotal = Math.max(0, ordinaryIncomeInclTaxableSS + preferentialIncome - standardDeduction);
      const taxablePreferential = Math.max(0, taxableTotal - taxableOrdinary);
      const ordinaryTax = bracketTax(taxableOrdinary, taxData.federal.ordinaryBrackets[filingStatus]);
      const ltcgTax = ltcgTaxAmount(filingStatus, taxableOrdinary, taxablePreferential);
      const niitThreshold = taxData.federal.niitThresholds[filingStatus];
      const niit = Math.max(0, Math.min(preferentialIncome, agi - niitThreshold)) * taxData.federal.niitRate;
      return ordinaryTax + ltcgTax + niit;
    }

    function calcStateTax(stateCode, filingStatus, ordinaryIncomeExcludingSS, preferentialIncome, ssIncome, ages) {
      if (stateCode === "TX") return 0;
      if (stateCode === "CA") {
        const taxable = Math.max(0, ordinaryIncomeExcludingSS + preferentialIncome - taxData.states.CA.standardDeduction[filingStatus]);
        const raw = bracketTax(taxable, taxData.states.CA.brackets[filingStatus]);
        return Math.max(0, raw - taxData.states.CA.personalExemptionCredit[filingStatus]);
      }
      if (stateCode === "GA") {
        const agesList = [ages.spouse1, ages.spouse2];
        const exclusion = agesList.reduce((sum, age) => {
          if (!Number.isFinite(age)) return sum;
          if (age >= 65) return sum + taxData.states.GA.retirementExclusion.age65plus;
          if (age >= 62) return sum + taxData.states.GA.retirementExclusion.age62to64;
          return sum;
        }, 0);
        const taxable = Math.max(0, ordinaryIncomeExcludingSS + preferentialIncome - taxData.states.GA.standardDeduction[filingStatus] - exclusion);
        return taxable * taxData.states.GA.flatRate;
      }
      return 0;
    }

    function calcIrmaaForYear(magiHistory, history, household, ages, year) {
      const lookbackYear = year - taxData.federal.irmaa.lookbackYears;
      const lookback = magiHistory[lookbackYear] || { magi: 0, filingStatus: "married_filing_jointly" };
      const aliveOnMedicare = [ages.spouse1, ages.spouse2].filter(age => age >= 65).length;
      if (!aliveOnMedicare) return 0;
      const filingStatus = lookback.filingStatus === "married_filing_jointly" ? "married_filing_jointly" : "single";
      const tiers = taxData.federal.irmaa.monthlyPremiums[filingStatus] || taxData.federal.irmaa.monthlyPremiums.married_filing_jointly;
      const monthly = (tiers.find(([max]) => (lookback.magi || 0) <= max) || tiers[tiers.length - 1])[1];
      return monthly * 12 * aliveOnMedicare;
    }

    function bracketTax(income, brackets) {
      let previous = 0;
      let tax = 0;
      for (const [rate, upper] of brackets) {
        const taxableSlice = Math.max(0, Math.min(income, upper) - previous);
        tax += taxableSlice * rate;
        previous = upper;
        if (income <= upper) break;
      }
      return tax;
    }

    function ltcgTaxAmount(filingStatus, taxableOrdinary, taxablePreferential) {
      if (taxablePreferential <= 0) return 0;
      const brackets = taxData.federal.ltcgBrackets[filingStatus];
      let remaining = taxablePreferential;
      let tax = 0;
      let usedOrdinary = taxableOrdinary;
      let previous = 0;
      for (const [rate, upper] of brackets) {
        if (remaining <= 0) break;
        const thresholdRoom = Math.max(0, upper - Math.max(previous, usedOrdinary));
        const slice = Math.min(remaining, thresholdRoom);
        tax += slice * rate;
        remaining -= slice;
        previous = upper;
      }
      return tax;
    }

    function targetBracketUpperBound(filingStatus, targetRate) {
      const brackets = taxData.federal.ordinaryBrackets[filingStatus];
      const entry = brackets.find(([rate]) => Number(rate) === Number(targetRate));
      return entry ? entry[1] : brackets[3][1];
    }

    function nextIrmaaThreshold(filingStatus, currentAgi) {
      const status = filingStatus === "married_filing_jointly" ? "married_filing_jointly" : "single";
      const tiers = taxData.federal.irmaa.monthlyPremiums[status];
      const upcoming = tiers.find(([threshold]) => currentAgi < threshold);
      return upcoming ? upcoming[0] : Infinity;
    }

    function marginalRateForIncome(filingStatus, taxableIncome) {
      const brackets = taxData.federal.ordinaryBrackets[filingStatus];
      for (const [rate, upper] of brackets) {
        if (taxableIncome <= upper) return rate;
      }
      return brackets.at(-1)[0];
    }

    function findAlerts(history, household, stateCode) {
      const alerts = [];
      const widowYearIndex = history.findIndex((row, index) => index > 0 && history[index - 1].filingStatus === "married_filing_jointly" && row.filingStatus === "single");
      if (widowYearIndex >= 0) {
        const row = history[widowYearIndex];
        alerts.push({ type: "danger", title: `Widow trap watch in ${row.year}`, text: `${stateCode}: filing status flips to single while RMD / conversion pressure continues.` });
      }
      const firstMedicareYear = history.find(row => row.irmaa > 0);
      if (firstMedicareYear) {
        alerts.push({ type: "warn", title: `Medicare starts in ${firstMedicareYear.year}`, text: `${stateCode}: baseline Medicare premiums begin once at least one spouse reaches 65.` });
      }
      const standardMarried = taxData.federal.irmaa.monthlyPremiums.married_filing_jointly[0][1];
      const standardSingle = taxData.federal.irmaa.monthlyPremiums.single[0][1];
      const irmaaSpike = history.find((row, index) => index > 0 && row.irmaa > history[index - 1].irmaa + 1000 && row.irmaa > 0 && row.irmaa !== (row.filingStatus === "married_filing_jointly" ? standardMarried * 12 * 2 : standardSingle * 12));
      if (irmaaSpike) {
        alerts.push({ type: "warn", title: `IRMAA surcharge in ${irmaaSpike.year}`, text: `${stateCode}: Medicare premiums step up based on the two-year MAGI lookback.` });
      }
      const firstRmd = history.find(row => row.rmd > 0);
      if (firstRmd) {
        alerts.push({ type: "warn", title: `First RMD year ${firstRmd.year}`, text: `${stateCode}: required distributions begin pushing taxable income higher.` });
      }
      const bestConversion = history.find(row => row.rothConversion > 0);
      if (bestConversion) {
        alerts.push({ type: "good", title: `Conversions active`, text: `${stateCode}: Roth conversions total ${currency(history.reduce((sum, row) => sum + row.rothConversion, 0))}.` });
      }
      return alerts;
    }

    function renderHeadlineMetrics() {
      const states = Object.values(projectionCache);
      if (!states.length) return;
      const best = [...states].sort((a, b) => b.endingNetWorth - a.endingNetWorth)[0];
      const worst = [...states].sort((a, b) => a.endingNetWorth - b.endingNetWorth)[0];
      const spread = best.endingNetWorth - worst.endingNetWorth;
      const allHistory = states.flatMap(s => s.history);
      const maxRmd = Math.max(...allHistory.map(row => row.rmd), 0);
      const widowAlertYear = states.map(s => s.alerts.find(a => a.title.includes("Widow trap"))?.title?.replace("Widow trap watch in ", "")).filter(Boolean)[0] || "—";
      document.getElementById("headlineMetrics").innerHTML = `
        <div class="metric-card">
          <div class="eyebrow">Best ending state</div>
          <div class="big">${best.stateCode}</div>
          <div class="delta">${currency(best.endingNetWorth)} ending wealth</div>
        </div>
        <div class="metric-card">
          <div class="eyebrow">Worst-to-best spread</div>
          <div class="big mono">${currency(spread)}</div>
          <div class="delta">Difference in final portfolio value</div>
        </div>
        <div class="metric-card">
          <div class="eyebrow">Peak annual RMD</div>
          <div class="big mono">${currency(maxRmd)}</div>
          <div class="delta">Largest forced tax-deferred distribution</div>
        </div>
        <div class="metric-card">
          <div class="eyebrow">Widow trap watch</div>
          <div class="big mono">${widowAlertYear}</div>
          <div class="delta">First projected single-filer year</div>
        </div>
      `;
    }

    function renderStateComparison() {
      const grid = document.getElementById("stateCompareGrid");
